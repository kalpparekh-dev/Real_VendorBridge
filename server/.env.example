# If your PostgreSQL password contains @, use %40 in the URL.
# Example password Kalp1234@ becomes Kalp1234%40
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_ENCODED@localhost:5432/vendorbridge?schema=public"
JWT_SECRET="vendorbridge-dev-secret-change-in-production"
JWT_REFRESH_SECRET="vendorbridge-refresh-secret-change-in-production"
PORT=5000
NODE_ENV=development
